generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  JUDGE
  LAWYER
  CLERK
}

enum CaseStatus {
  DRAFT
  PENDING
  ACTIVE
  ON_HOLD
  CLOSED
}

enum DocumentType {
  EVIDENCE
  ORDER
  PLEADING
  MOTION
  BRIEF
  CONTRACT
  OTHER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model User {
  id             String          @id @default(cuid())
  name           String
  email          String          @unique
  password       String
  role           Role            @default(CLERK)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  createdCases   Case[]          @relation("CaseCreator")
  judgedCases    Case[]          @relation("CaseJudge")
  assignments    CaseAssignment[]
  uploadedDocs   Document[]
  accessLogs     AccessLog[]
  tasks          CaseTask[]
  comments       CaseComment[]
}

model Case {
  id             String          @id @default(cuid())
  caseNumber     String          @unique
  title          String
  description    String?
  status         CaseStatus      @default(DRAFT)
  isRestricted   Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  creatorId      String
  creator        User            @relation("CaseCreator", fields: [creatorId], references: [id])

  judgeId        String?
  judge          User?           @relation("CaseJudge", fields: [judgeId], references: [id])

  assignments    CaseAssignment[]
  documents      Document[]
  accessLogs     AccessLog[]
  tasks          CaseTask[]
  comments       CaseComment[]
}

model CaseAssignment {
  id        String   @id @default(cuid())
  caseId    String
  userId    String
  role      Role
  assignedAt DateTime @default(now())

  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([caseId, userId])
}

model Document {
  id           String       @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  type         DocumentType @default(OTHER)
  version      Int          @default(1)
  path         String
  createdAt    DateTime     @default(now())

  caseId       String
  case         Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)

  uploadedById String
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])

  accessLogs   AccessLog[]
}

model AccessLog {
  id          String   @id @default(cuid())
  action      String
  ip          String?
  userAgent   String?
  timestamp   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  caseId      String?
  case        Case?    @relation(fields: [caseId], references: [id])

  documentId  String?
  document    Document? @relation(fields: [documentId], references: [id])
}

model CaseTask {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  caseId      String
  case        Case       @relation(fields: [caseId], references: [id], onDelete: Cascade)

  assignedToId String?
  assignedTo   User?     @relation(fields: [assignedToId], references: [id])
}

model CaseComment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
}
