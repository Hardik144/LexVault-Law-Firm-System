{
  "title": "LexVault Backend",
  "uid": "lawfirm-backend",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{
        "expr": "rate(lawfirm_http_requests_total[1m])",
        "legendFormat": "{{method}} {{route}} {{status_code}}",
        "datasource": "Prometheus"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 2,
      "title": "HTTP Response Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(lawfirm_http_request_duration_seconds_bucket[5m]))",
        "legendFormat": "p95 latency",
        "datasource": "Prometheus"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 3,
      "title": "Node.js Heap Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{
        "expr": "lawfirm_nodejs_heap_size_used_bytes",
        "legendFormat": "Heap Used",
        "datasource": "Prometheus"
      }],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 4,
      "title": "Active Handles",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [{
        "expr": "lawfirm_nodejs_active_handles_total",
        "legendFormat": "Active Handles",
        "datasource": "Prometheus"
      }]
    },
    {
      "id": 5,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [{
        "expr": "rate(lawfirm_http_requests_total{status_code=~\"5..\"}[1m])",
        "legendFormat": "5xx errors/s",
        "datasource": "Prometheus"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "fixedColor": "red", "mode": "fixed" } } }
    }
  ]
}
